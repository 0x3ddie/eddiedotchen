{
  "name": "personal-website-next",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0 <23.0.0"
  },
  "scripts": {
    "preflight": "node scripts/preflight.mjs",
    "predev": "npm run preflight",
    "prebuild": "npm run preflight",
    "dev": "npm run generate && next dev",
    "build": "NODE_ENV=production npm run generate && next build && npm run sitemap",
    "start": "next start",
    "lint": "next lint",
    "generate": "npm run sync:scaling-book && node scripts/generate-content.mjs",
    "sync:scaling-book": "node scripts/sync-scaling-book.mjs",
    "sitemap": "node scripts/generate-sitemap.mjs"
  },
  "dependencies": {
    "@chakra-ui/react": "^2.4.6",
    "@emotion/react": "^11.10.5",
    "@emotion/styled": "^11.10.5",
    "@mdx-js/loader": "^2.2.1",
    "@mdx-js/react": "^2.2.1",
    "@next/font": "13.1.1",
    "@next/mdx": "^13.1.1",
    "@nikolovlazar/chakra-ui-prose": "^1.2.1",
    "@types/node": "18.11.18",
    "@types/react": "18.0.26",
    "@types/react-dom": "18.0.10",
    "@vercel/analytics": "^2.0.1",
    "eslint": "8.31.0",
    "eslint-config-next": "13.1.1",
    "framer-motion": "^8.0.2",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.47",
    "next": "13.1.1",
    "next-mdx-remote": "^6.0.0",
    "next-seo": "^5.15.0",
    "posthog-js": "^1.39.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-icons": "^4.7.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "typescript": "4.9.4"
  }
